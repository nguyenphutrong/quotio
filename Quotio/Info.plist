<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sparkle Auto-Update Configuration -->
    <key>SUFeedURL</key>
    <string>$(QUOTIO_SPARKLE_FEED_URL)</string>
    
    <key>SUPublicEDKey</key>
    <string>HBpWFjUcNUuuZfdxhVlw2Mc87IT8tj1C68rufluZ0M4=</string>
    
    <key>SUEnableAutomaticChecks</key>
    <true/>
    
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>

    <key>QuotioUpdatesEnabled</key>
    <string>$(QUOTIO_ENABLE_UPDATES)</string>
    
    <!-- App Info -->
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2025 Quotio. All rights reserved.</string>
    
    <!-- URL Scheme -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>$(QUOTIO_URL_NAME)</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>$(QUOTIO_URL_SCHEME)</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
