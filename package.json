{
  "name": "quotio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "contracts:check": "node tools/contract-codegen/generate.mjs --check",
    "contracts:generate": "node tools/contract-codegen/generate.mjs",
    "dev": "turbo dev",
    "desktop-ui:bootstrap:check": "bun apps/desktop-ui/src/lib/admin/bootstrap.test.ts",
    "desktop-ui:gateway-url:check": "bun apps/desktop-ui/src/lib/admin/gateway-url.test.ts",
    "desktop-ui:native-feel:check": "node tools/native-feel-gates/check.mjs",
    "format-and-lint": "biome check apps packages tools schema generated package.json tsconfig.json tsconfig.base.json turbo.json",
    "format-and-lint:fix": "biome check apps packages tools schema generated package.json tsconfig.json tsconfig.base.json turbo.json --write",
    "macos:shared-ui:bundled": "./scripts/run-macos-shared-ui.sh bundled",
    "macos:shared-ui:dev": "./scripts/run-macos-shared-ui.sh",
    "smoke:agents": "./scripts/run-codex-patcher-smoke.sh && ./scripts/run-agent-config-smoke.sh",
    "typecheck": "turbo typecheck",
    "windows:gates:check": "node tools/windows-preview-gates/check.mjs",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "lefthook": "^1.11.13",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.3",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
